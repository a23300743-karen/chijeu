<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".tarjeta">

    <Button
        android:id="@+id/btnRegresar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="10dp"
        android:text="Regresar"
        android:backgroundTint="@color/green"
        android:fontFamily="@font/creato"
        android:textSize="15sp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="600dp"
        android:layout_margin="20dp"
        app:cardElevation="15dp"
        app:cardCornerRadius="25dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtNom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Modelo"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtMarc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Marca"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtEmpresa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Fabricante"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Precio"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtPais"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Pais"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTelefono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Teléfono"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTipoLeche"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Cuerpo"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtProceso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Pastillas"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtPresentacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Puente"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtSabor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Maderas"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtPeso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Cuerdas"
                android:textSize="18sp"
                android:textColor="@color/yellow"
                android:fontFamily="@font/creato"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnLlamar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/yellow"
                android:text="Llamar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/creato"
                app:icon="@android:drawable/sym_action_call"/>


        </LinearLayout>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/guitarra"
            android:layout_gravity="center"
            android:alpha="0.3"/>

    </androidx.cardview.widget.CardView>

</LinearLayout>